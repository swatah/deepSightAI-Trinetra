FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    bash \
    ca-certificates \
    gnupg \
    lsb-release \
    apt-transport-https \
    && rm -rf /var/lib/apt/lists/*

# Install Docker CLI (for communicating with host Docker daemon via mounted socket)
RUN curl -fsSL https://get.docker.com -o get-docker.sh && \
    sh get-docker.sh && \
    rm get-docker.sh

# Install kubectl from Debian repositories (reliable)
RUN apt-get update && apt-get install -y kubectl && \
    rm -rf /var/lib/apt/lists/*

# Install Helm via official script
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# Note: k3d binary may not be installed (tests will skip if not present)
# kustomize is not needed - we use kubectl kustomize which is built-in

# Install Helm (moved after Docker to ensure it's available)
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# Set working directory
WORKDIR /workspace

# Copy requirements first (cache layer)
COPY Embedder/requirements_embedder.txt /workspace/requirements_embedder.txt
COPY ["Server and Extractor/requirements.txt", "/workspace/requirements.txt"]
COPY UI/requirements_ui.txt /workspace/requirements_ui.txt
RUN pip install --no-cache-dir -r requirements.txt -r requirements_embedder.txt -r requirements_ui.txt \
    && pip install --no-cache-dir pytest pytest-cov pytest-xdist pyyaml

# Copy source code
COPY . .

# Default command - can be overridden
CMD ["pytest", "tests/unit/", "-v"]
